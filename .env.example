# Site URL (used for sitemap and OG tags)
NEXT_PUBLIC_SITE_URL=https://velencevill.hu

# Admin panel password (required — no fallback)
ADMIN_PASSWORD=your_secure_password_here

# Resend email service (required for form submissions)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@velencevill.hu
RESEND_TO_EMAIL=info@velencevill.hu

# Supabase (optional — for lead storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
